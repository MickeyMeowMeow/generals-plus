{
  "name": "@generals-plus/engine",
  "private": true,
  "version": "0.1.0",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "imports": {
    "#*": [
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "scripts": {
    "build": "tsdown src/index.ts",
    "dev": "tsdown src/index.ts --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@generals-plus/typescript-config": "workspace:*",
    "@generals-plus/vitest-config": "workspace:*",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.5"
  }
}
